---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 4rem;">
      <div class="hero-content" style="flex: 1; min-width: 320px;">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Monitoramento 24h · Rio de Janeiro
        </div>
        <h1 style="text-shadow: 0 4px 20px rgba(0,0,0,0.8);">
          Sua família e seu patrimônio
          <span class="destaque">protegidos de verdade</span>
        </h1>
        <p class="hero-sub" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8); max-width: 600px; font-size: 1.15rem;">
          Não espere acontecer. Instale o sistema da maior empresa de segurança eletrônica da América Latina e monitore tudo em tempo real.
        </p>
        <div class="hero-ctas">
          <a href="#typebot" class="btn-primario">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Falar com Especialista
          </a>
          <a href="#servicos" class="btn-secundario">
            Ver Serviços
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">500+</span>
            <span class="stat-label">Instalações</span>
          </div>
          <div class="stat">
            <span class="stat-num">24h</span>
            <span class="stat-label">Monitoramento</span>
          </div>
          <div class="stat">
            <span class="stat-num">10+</span>
            <span class="stat-label">Anos de Experiência</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Garantia</span>
          </div>
        </div>
      </div>
      <div class="hero-image fade-up" style="flex: 1; min-width: 300px; display: flex; justify-content: center; position: relative; z-index: 1;">
        <img src="/helder-alarme-seguranca.jpg" alt="Helder Oliveira - Especialista em Segurança Eletrônica" style="max-width: 100%; border-radius: 20px; box-shadow: 0 20px 40px rgba(0,0,0,0.6); border: 2px solid rgba(242,183,5,0.4);" />
      </div>
    </div>
  </section>

  <!-- ============ FAIXA DE CONFIANÇA ============ -->
  <div class="faixa-confianca" aria-label="Serviços">
    <div class="faixa-confianca-track" aria-hidden="true">
      <span class="faixa-item">🔒 Monitoramento 24h</span>
      <span class="faixa-item">📷 CFTV Profissional</span>
      <span class="faixa-item">🚨 Alarmes Inteligentes</span>
      <span class="faixa-item">⚡ Cerca Elétrica</span>
      <span class="faixa-item">🏠 Residencial &amp; Comercial</span>
      <span class="faixa-item">📱 App de Monitoramento</span>
      <span class="faixa-item">🔒 Monitoramento 24h</span>
      <span class="faixa-item">📷 CFTV Profissional</span>
      <span class="faixa-item">🚨 Alarmes Inteligentes</span>
      <span class="faixa-item">⚡ Cerca Elétrica</span>
      <span class="faixa-item">🏠 Residencial &amp; Comercial</span>
      <span class="faixa-item">📱 App de Monitoramento</span>
    </div>
  </div>

  <!-- ============ DORES / BENEFÍCIOS ============ -->
  <section class="dores" id="beneficios">
    <div class="container">
      <div class="fade-up">
        <span class="badge">Por Que Agir Agora?</span>
        <h2 class="titulo-secao" style="margin-top:0.75rem">
          O Rio de Janeiro não espera.<br/>
          <span>E você também não deveria.</span>
        </h2>
        <p class="subtitulo-secao">
          A criminalidade aumenta enquanto você descansa. Com o sistema certo, você monitora tudo de forma profissional e age antes que o problema chegue.
        </p>
        <div style="text-align: center; margin-top: 2rem;">
          <img src="/alarme-rj.jpg" alt="Sistema de Alarme e Segurança RJ" style="max-width: 100%; border-radius: 12px; max-height: 300px; object-fit: cover; opacity: 0.9; box-shadow: 0 4px 15px rgba(0,0,0,0.1);" loading="lazy" />
        </div>
      </div>
      <div class="cards-grade">
        <div class="card fade-up">
          <div class="card-icon">👁️</div>
          <h3>Visibilidade Total</h3>
          <p>Câmeras de alta resolução registram tudo, dia e noite. Acesse ao vivo pelo celular de qualquer lugar do mundo.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">🚨</div>
          <h3>Resposta Imediata</h3>
          <p>Ao menor sinal suspeito, o sistema dispara alertas e aciona a central de monitoramento 24 horas.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">🛡️</div>
          <h3>Proteção Certificada</h3>
          <p>Equipamentos homologados pela Anatel com garantia total. Parceiro autorizado EMIVE — líder em segurança eletrônica no Brasil.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">💼</div>
          <h3>Projeto Personalizado</h3>
          <p>Cada propriedade é única. Fazemos um estudo completo do seu ambiente antes de qualquer instalação.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">📱</div>
          <h3>Controle no seu Celular</h3>
          <p>Arme, desarme, confira câmeras e receba notificações em tempo real diretamente no seu smartphone.</p>
        </div>
        <div class="card fade-up">
          <div class="card-icon">🏆</div>
          <h3>Garantia e Suporte</h3>
          <p>Suporte técnico prioritário e garantia em todos os equipamentos. Você nunca fica sem cobertura.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVIÇOS ============ -->
  <section class="servicos" id="servicos">
    <div class="container">
      <div class="secao-header fade-up">
        <span class="badge">Nossos Serviços</span>
        <h2 class="titulo-secao" style="margin-top:0.75rem">
          Soluções completas em<br/><span>segurança eletrônica</span>
        </h2>
        <div class="divisor"></div>
        <p class="subtitulo-secao" style="margin-inline:auto;text-align:center">
          Do projeto à manutenção, cuidamos de tudo para sua tranquilidade
        </p>
      </div>
      <div class="servicos-grade">
        <div class="servico-card fade-up">
          <span class="servico-icon">📷</span>
          <div class="servico-info">
            <h3>CFTV / Câmeras de Segurança</h3>
            <p>Câmeras Full HD e 4K, infravermelho, visão noturna colorida e armazenamento em nuvem ou DVR local.</p>
          </div>
        </div>
        <div class="servico-card fade-up">
          <span class="servico-icon">🚨</span>
          <div class="servico-info">
            <h3>Alarmes Monitorados 24h</h3>
            <p>Sensores de presença, magnéticos e de vibração integrados à central de monitoramento com resposta imediata.</p>
          </div>
        </div>
        <div class="servico-card fade-up">
          <span class="servico-icon">⚡</span>
          <div class="servico-info">
            <h3>Cerca Elétrica</h3>
            <p>Perímetro protegido com choque seguro e alarme instantâneo. Ideal para residências e empresas.</p>
          </div>
        </div>
        <div class="servico-card fade-up">
          <span class="servico-icon">🚪</span>
          <div class="servico-info">
            <h3>Controle de Acesso</h3>
            <p>Catracas, biometria, cartão de proximidade e interfone IP para controle total de quem entra e sai.</p>
          </div>
        </div>
        <div class="servico-card fade-up">
          <span class="servico-icon">🔥</span>
          <div class="servico-info">
            <h3>Detecção de Incêndio</h3>
            <p>Detectores de fumaça e calor integrados ao sistema de alarme, com acionamento automático.</p>
          </div>
        </div>
        <div class="servico-card fade-up">
          <span class="servico-icon">🔧</span>
          <div class="servico-info">
            <h3>Manutenção Preventiva</h3>
            <p>Planos de manutenção periódica para manter seu sistema sempre funcionando em 100%.</p>
          </div>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 4rem;" class="fade-up">
        <img src="/seguranca-eletronica-rj.jpg" alt="Segurança Eletrônica no Rio de Janeiro" style="width: 100%; height: 220px; object-fit: cover; object-position: top; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);" loading="lazy" />
        <img src="/alarme-seguranca-residencial.jpg" alt="Alarme de Segurança Residencial" style="width: 100%; height: 220px; object-fit: cover; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);" loading="lazy" />
        <img src="/sistema-de-alarme-rj.jpg" alt="Sistema de Alarme RJ" style="width: 100%; height: 220px; object-fit: cover; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);" loading="lazy" />
        <img src="/sistema-de-cameras-de-seguranca-rj.jpg" alt="Câmeras e CFTV" style="width: 100%; height: 220px; object-fit: cover; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ============ TYPEBOT EMBED ============ -->
  <section class="typebot-secao" id="typebot">
    <div class="container">
      <div class="typebot-wrapper">
        <div class="typebot-info fade-up">
          <span class="badge">Orçamento Grátis</span>
          <h2 class="titulo-secao" style="margin-top:0.75rem">
            Fale agora com um
            <span>especialista</span>
          </h2>
          <div class="divisor"></div>
          <p style="color:#CBD5E1;margin-top:0.5rem;line-height:1.7">
            Responda algumas perguntas rápidas e receba uma proposta personalizada para o seu imóvel — sem compromisso.
          </p>
          <ul class="typebot-lista">
            <li>Atendimento em até 24 horas</li>
            <li>Visita técnica gratuita no Rio de Janeiro</li>
            <li>Proposta apresentada no mesmo dia</li>
            <li>Parcelamento em até 12x sem juros</li>
            <li>Garantia em todos os equipamentos</li>
          </ul>
        </div>

        <!-- TYPEBOT EMBED DIRETO — sem botão -->
        <div class="typebot-container fade-up" id="typebot-container">
          <div class="typebot-header">
            <div class="typebot-header-dot"></div>
            <span class="typebot-header-title">🛡️ Helder Oliveira Security · Online agora</span>
          </div>
          <div class="typebot-embed-area">
            <typebot-standard
              style="width: 100%; height: 100%;"
            ></typebot-standard>
            <script type="module" is:inline>
              import Typebot from 'https://cdn.jsdelivr.net/npm/@typebot.io/js@0.3/dist/web.js';
              Typebot.initStandard({
                typebot: "emivepromoexclusiva",
              });
            </script>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ DEPOIMENTOS ============ -->
  <section class="depoimentos" id="depoimentos">
    <div class="container">
      <div class="secao-header fade-up">
        <span class="badge">Depoimentos Reais</span>
        <h2 class="titulo-secao" style="margin-top:0.75rem">
          Quem protegeu seu lar com a gente
          <span>recomenda</span>
        </h2>
        <div class="divisor"></div>
      </div>
      <div class="depoimentos-grade">
        <div class="depoimento-card fade-up">
          <div class="depoimento-stars">★★★★★</div>
          <p class="depoimento-texto">"Instalaram o sistema completo na minha casa em Barra da Tijuca em um dia. A equipe foi muito profissional e o suporte pós-instalação é excelente. Recomendo demais!"</p>
          <div class="depoimento-autor">
            <img src="/homem-2-seguranca-eletronica.jpg" alt="Ricardo Moura" style="width: 42px; height: 42px; border-radius: 50%; object-fit: cover;" />
            <div>
              <div class="depoimento-nome">Ricardo Moura</div>
              <div class="depoimento-local">Barra da Tijuca, RJ</div>
            </div>
          </div>
        </div>
        <div class="depoimento-card fade-up">
          <div class="depoimento-stars">★★★★★</div>
          <p class="depoimento-texto">"Minha empresa ficou 2 anos sem um sistema eficiente. O Helder fez um projeto completo com câmeras e alarme monitorado. Investimento que valeu muito a pena."</p>
          <div class="depoimento-autor">
            <img src="/mulher-seguranca-eletronica.jpg" alt="Carla Ferreira" style="width: 42px; height: 42px; border-radius: 50%; object-fit: cover;" />
            <div>
              <div class="depoimento-nome">Carla Ferreira</div>
              <div class="depoimento-local">Tijuca, RJ</div>
            </div>
          </div>
        </div>
        <div class="depoimento-card fade-up">
          <div class="depoimento-stars">★★★★★</div>
          <p class="depoimento-texto">"Após a instalação da cerca elétrica e das câmeras, dormimos muito mais tranquilos. Atendimento rápido, preço justo e suporte sempre disponível."</p>
          <div class="depoimento-autor">
            <img src="/homem-seguranca-eletronica.jpg" alt="Paulo Lima" style="width: 42px; height: 42px; border-radius: 50%; object-fit: cover;" />
            <div>
              <div class="depoimento-nome">Paulo Lima</div>
              <div class="depoimento-local">Jacarepaguá, RJ</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA FINAL ============ -->
  <section class="cta-final">
    <div class="container">
      <span class="badge" style="background:rgba(0,0,0,0.12);border-color:rgba(0,0,0,0.2);color:#0A0A0A;margin-bottom:1rem">Proteção Real Para o RJ</span>
      <h2>Não deixe para depois.<br/>Sua segurança começa hoje.</h2>
      <p>Temos disponibilidade para atender no Rio de Janeiro ainda esta semana. Solicite sua visita técnica gratuita agora.</p>
      <a href="#typebot" class="btn-cta-escuro">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Solicitar Orçamento Grátis
      </a>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <div class="footer-logo">
            <span style="color:#FFF;">Helder</span> 
            <span style="color:#FFF;">Oliveira</span>
            <span style="display:block; font-size: 0.9rem; margin-top: 0.2rem; font-weight: 500; color:var(--cinza-claro);">Parceiro Autorizado <span style="color:var(--amarelo); font-weight: 900; letter-spacing: 1px;">EMIVE</span></span>
          </div>
          <p class="footer-desc">
            Segurança eletrônica com a tecnologia líder absoluta no Brasil. Proteção 24h inteligente para residências e empresas.
          </p>
        </div>
        <div>
          <div class="footer-titulo">Serviços</div>
          <ul class="footer-lista">
            <li>CFTV / Câmeras</li>
            <li>Alarmes Monitorados</li>
            <li>Cerca Elétrica</li>
            <li>Controle de Acesso</li>
            <li>Manutenção</li>
          </ul>
        </div>
        <div>
          <div class="footer-titulo">Contato</div>
          <ul class="footer-lista">
            <li>📱 (21) 97115-1977</li>
            <li>📍 Rio de Janeiro, RJ</li>
            <li>🕒 Seg–Sáb 8h–18h</li>
            <li>🚨 Plantão 24h</li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">© {new Date().getFullYear()} Helder Oliveira Security. Todos os direitos reservados.</span>
        <span class="footer-copy">Parceiro Autorizado <strong style="color:#F2B705">EMIVE</strong></span>
      </div>
    </div>
  </footer>

  <!-- ============ WHATSAPP FLUTUANTE ============ -->
  <a
    href="https://wa.me/5521971151977?text=Olá!%20Vim%20pelo%20site%20e%20gostaria%20de%20um%20orçamento%20de%20segurança%20eletrônica."
    class="whatsapp-float"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Falar pelo WhatsApp"
    id="whatsapp-btn"
  >
    <span class="whatsapp-tooltip">Falar no WhatsApp</span>
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Script para animações de scroll -->
  <script>
    // Intersection Observer para fade-up
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.12 }
    );

    document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
